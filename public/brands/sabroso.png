<script>
  (function () {
    // Lock checkout at page load — before the widget bundle even loads — so a
    // customer can't bypass the pickup/delivery flow during the window where the
    // widget is still loading (the shops?identifier fetch). Uses the same
    // `genie-checkout-loading` class the widget's React app manages, so once it
    // mounts it owns these buttons and re-enables them when ready.
    var LOCK_CLASS = 'genie-checkout-loading';
    var MOUNTED_SELECTOR = '[data-genie-store-pickup-mounted="1"]';

    function lockCheckout() {
      var btns = document.querySelectorAll('[name="checkout"]');
      for (var i = 0; i < btns.length; i++) {
        if (!btns[i].classList.contains(LOCK_CLASS)) {
          btns[i].setAttribute('disabled', 'disabled');
          btns[i].classList.add(LOCK_CLASS);
        }
      }
    }

    function releaseCheckout() {
      var btns = document.querySelectorAll('.' + LOCK_CLASS);
      for (var i = 0; i < btns.length; i++) {
        btns[i].removeAttribute('disabled');
        btns[i].classList.remove(LOCK_CLASS);
      }
    }

    lockCheckout();

    // Themes often render the cart/drawer checkout button after this runs, so
    // re-apply until the widget mounts and takes over.
    var ticks = 0;
    var relockInterval = setInterval(function () {
      // Once the React widget has mounted it owns the buttons — stop re-locking
      // so its toggleCheckoutButtons can enable/disable them as the flow dictates.
      if (document.querySelector(MOUNTED_SELECTOR)) {
        clearInterval(relockInterval);
        return;
      }
      lockCheckout();
      if (++ticks >= 60) clearInterval(relockInterval); // ~9s of coverage at 150ms
    }, 150);

    // Failsafe: if the widget never mounts (bundle failed to load, pickup not in
    // use on this page, etc.), release the lock so checkout is NEVER permanently
    // blocked. If it did mount, leave the buttons to the widget.
    setTimeout(function () {
      clearInterval(relockInterval);
      if (!document.querySelector(MOUNTED_SELECTOR)) {
        releaseCheckout();
      }
    }, 15000);
  })();

  (function () {
    var root = document.getElementById('genie-feature-embed');
    var input = document.getElementById('genie-shopify-domain');
    if (!root || !input || !input.value || !String(input.value).trim()) {
      return;
    }

    var apiBase = (root.getAttribute('data-app-url') || '').replace(/\/$/, '');
    if (!apiBase) {
      return;
    }

    function addCss(href) {
      if (!href) return;
      var l = document.createElement('link');
      l.rel = 'stylesheet';
      l.href = href;
      document.head.appendChild(l);
    }

    function addScript(src, opts) {
      opts = opts || {};
      if (!src) return;
      var s = document.createElement('script');
      s.src = src;
      if (opts.defer) {
        s.defer = true;
      }
      if (opts.onload) {
        s.onload = function () {
          try {
            opts.onload();
          } catch (e) {
            if (typeof console !== 'undefined' && console.error) {
              console.error('[Genie feature]', e);
            }
          }
        };
      }
      if (opts.onerror) {
        s.onerror = opts.onerror;
      }
      document.body.appendChild(s);
    }

    function callInit(name) {
      var fn = window[name];
      if (typeof fn === 'function') {
        fn();
      }
    }

    var url = apiBase + '/api/v1/shop_extra_feature_flags?shopify_domain=' + encodeURIComponent(String(input.value).trim());
    fetch(url, { method: 'GET', credentials: 'omit', mode: 'cors' })
      .then(function (r) {
        if (!r.ok) throw new Error('bad response');
        return r.json();
      })
      .then(function (flags) {
        if (flags.trusted_badges_enabled) {
          addCss(root.getAttribute('data-trusted-badges-css'));
          addScript(root.getAttribute('data-trusted-badges-js'), {
            onload: function () {
              callInit('GenieTrustedBadgesInit');
            },
          });
        }
        if (flags.speed_optimizer_enabled) {
          addCss(root.getAttribute('data-speed-optimizer-css'));
          addScript(root.getAttribute('data-speed-optimizer-js'), {
            defer: true,
            onload: function () {
              callInit('GenieSpeedOptimizerInit');
            },
          });
        }
        if (flags.wishlist_enabled) {
          addCss(root.getAttribute('data-wishlist-css'));
          addScript(root.getAttribute('data-wishlist-js'), {
            defer: true,
            onload: function () {
              callInit('GenieWishlistInit');
            },
          });
        }
        if (flags.upsell_enabled) {
          var cfgEl = document.getElementById('genie-upsell-config-json');
          try {
            window.GenieUpsellConfig = cfgEl ? JSON.parse(cfgEl.textContent || 'null') : null;
          } catch (e) {
            window.GenieUpsellConfig = null;
          }
          window.GenieUpsellPageType = root.getAttribute('data-page-type') || '';
          if (root.getAttribute('data-upsell-product-id')) {
            window.GenieUpsellProduct = {
              id: root.getAttribute('data-upsell-product-id'),
              collections: root.getAttribute('data-upsell-collections') || '',
            };
          }
          addCss(root.getAttribute('data-upsell-css'));
          addScript(root.getAttribute('data-upsell-js'), {
            defer: true,
            onload: function () {
              var pt = root.getAttribute('data-page-type') || '';
              if (pt === 'collection' || pt === 'index') {
                window.GenieAddProductIds = true;
              }
              callInit('GenieUpsellInit');
            },
          });
        }
      })
      .catch(function () {});
  })();
</script>

